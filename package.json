{
	"name": "ixcamper-news",
	"version": "0.0.0",
	"scripts": {
		"ng": "ng",
		"start": "ng serve",
		"build": "ng build",
		"watch": "ng build --watch --configuration development",
		"test": "ng test --coverage --coverage-reporters=html",
		"server": "node ./api/index.js"
	},
	"prettier": {
		"printWidth": 100,
		"singleQuote": true,
		"overrides": [
			{
				"files": "*.html",
				"options": {
					"parser": "angular"
				}
			}
		]
	},
	"private": true,
	"packageManager": "npm@11.9.0",
	"dependencies": {
		"@angular/common": "^21.1.0",
		"@angular/compiler": "^21.1.0",
		"@angular/core": "^21.1.0",
		"@angular/forms": "^21.1.0",
		"@angular/platform-browser": "^21.1.0",
		"@angular/router": "^21.1.0",
		"axios": "^1.13.6",
		"bootstrap": "^5.3.8",
		"express": "^5.2.1",
		"rxjs": "~7.8.0",
		"tslib": "^2.3.0",
		"xml2js": "^0.6.2"
	},
	"devDependencies": {
		"@angular/build": "^21.1.3",
		"@angular/cli": "^21.1.3",
		"@angular/compiler-cli": "^21.1.0",
		"@vitest/coverage-v8": "^4.0.18",
		"jsdom": "^27.1.0",
		"typescript": "~5.9.2",
		"vitest": "^4.0.8"
	}
}